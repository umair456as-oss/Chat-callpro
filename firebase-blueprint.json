{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isVerified": { "type": "boolean" },
        "isBanned": { "type": "boolean" },
        "bio": { "type": "string" },
        "isShadowBanned": { "type": "boolean" },
        "level": { "type": "string", "enum": ["Bronze", "Silver", "Gold"] },
        "experience": { "type": "number" },
        "currentGame": { "type": "string" },
        "blockedUntil": { "type": "string", "format": "date-time" },
        "wallpaper": { "type": "string" },
        "ipAddress": { "type": "string" },
        "deviceFingerprint": { "type": "string" },
        "clickCount": { "type": "number" },
        "lastClickTime": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "balance", "role"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message between users",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] },
        "type": { "type": "string", "enum": ["text", "voice", "image", "support"] },
        "audioUrl": { "type": "string" },
        "replyTo": { "type": "string" },
        "isForwarded": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal request from a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["EasyPaisa", "JazzCash"] },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "taxAmount": { "type": "number" },
        "netAmount": { "type": "number" },
        "auditLog": {
          "type": "object",
          "properties": {
            "ip": { "type": "string" },
            "device": { "type": "string" }
          }
        }
      },
      "required": ["userId", "amount", "paymentMethod", "phoneNumber", "status", "timestamp"]
    },
    "GameLog": {
      "title": "GameLog",
      "description": "Log of game plays and earnings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "gameName": { "type": "string" },
        "reward": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "gameName", "reward", "timestamp"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "isMaintenanceMode": { "type": "boolean" },
        "adFrequency": { "type": "number" },
        "globalAnnouncement": { "type": "string" },
        "isWithdrawalsEnabled": { "type": "boolean" },
        "isGamesEnabled": { "type": "boolean" },
        "withdrawalTax": { "type": "number" },
        "isJackpotHour": { "type": "boolean" },
        "jackpotEndTime": { "type": "string", "format": "date-time" },
        "tickerMessages": { "type": "array", "items": { "type": "string" } },
        "rewardMultiplier": { "type": "number" },
        "minWithdrawal": { "type": "number" },
        "adEarningRate": { "type": "number" },
        "tickerText": { "type": "string" }
      },
      "required": ["isMaintenanceMode", "adFrequency", "isWithdrawalsEnabled", "isGamesEnabled"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Live support ticket for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "status", "updatedAt", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "System activity log for terminal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "action", "timestamp"]
    },
    "RevenueStats": {
      "title": "RevenueStats",
      "description": "Daily revenue and payout statistics",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "adRevenue": { "type": "number" },
        "userPayouts": { "type": "number" },
        "profit": { "type": "number" }
      },
      "required": ["date", "adRevenue", "userPayouts", "profit"]
    },
    "GameSettings": {
      "title": "GameSettings",
      "description": "Settings for individual games",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "earningRate": { "type": "number" },
        "isEnabled": { "type": "boolean" },
        "dailyLimit": { "type": "number" }
      },
      "required": ["id", "name", "earningRate", "isEnabled", "dailyLimit"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Application-wide announcements",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "type", "isActive", "createdAt"]
    },
    "Call": {
      "title": "Call",
      "description": "Voice or video call between users",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "receiverId": { "type": "string" },
        "callerName": { "type": "string" },
        "callerPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["calling", "ongoing", "ended", "missed", "rejected"] },
        "type": { "type": "string", "enum": ["voice", "video"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "offer": { "type": "object" },
        "answer": { "type": "object" }
      },
      "required": ["callerId", "receiverId", "callerName", "status", "type", "timestamp"]
    },
    "AdminSettings": {
      "title": "AdminSettings",
      "description": "Sensitive administrative settings",
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "adTimer": { "type": "number" }
      },
      "required": ["enabled"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Withdrawal requests"
    },
    "/gameLogs/{logId}": {
      "schema": "GameLog",
      "description": "Game play logs"
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings"
    },
    "/admin_settings/{settingId}": {
      "schema": "AdminSettings",
      "description": "Administrative settings like ads toggle"
    },
    "/supportTickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Support tickets"
    },
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "System activity logs"
    },
    "/revenueStats/{statId}": {
      "schema": "RevenueStats",
      "description": "Daily revenue statistics"
    },
    "/gameSettings/{gameId}": {
      "schema": "GameSettings",
      "description": "Settings for individual games"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global announcements"
    },
    "/calls/{callId}": {
      "schema": "Call",
      "description": "Voice and video calls"
    }
  }
}
